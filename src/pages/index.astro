<script>
	function initCarousel(carouselId: string) {
		const carousel = document.getElementById(carouselId);
		const track = carousel?.querySelector(
			".carousel-track",
		) as HTMLElement | null;
		const nextBtn = document.querySelector(
			`.next-btn[data-carousel="${carouselId}"]`,
		);
		const prevBtn = document.querySelector(
			`.prev-btn[data-carousel="${carouselId}"]`,
		);

		if (carousel && track && nextBtn && prevBtn) {
			let currentOffset = 0;

			nextBtn.addEventListener("click", () => {
				const card = track.querySelector(
					".carousel-card",
				) as HTMLElement | null;
				if (card) {
					const cardWidth = card.offsetWidth;
					const gap =
						parseFloat(window.getComputedStyle(track).gap) || 32;
					const shift = cardWidth + gap;

					const maxScroll = track.scrollWidth - carousel.clientWidth;
					if (Math.abs(currentOffset) < maxScroll) {
						currentOffset -= shift;
						if (Math.abs(currentOffset) > maxScroll)
							currentOffset = -maxScroll;
						track.style.transform = `translateX(${currentOffset}px)`;
					}
				}
			});
			prevBtn.addEventListener("click", () => {
				const card = track.querySelector(
					".carousel-card",
				) as HTMLElement | null;
				if (card) {
					const cardWidth = card.offsetWidth;
					const gap =
						parseFloat(window.getComputedStyle(track).gap) || 32;
					const shift = cardWidth + gap;

					currentOffset += shift;
					if (currentOffset > 0) currentOffset = 0;
					track.style.transform = `translateX(${currentOffset}px)`;
				}
			});
		}
	}

	function initPoemLogic() {
		// Initialize all carousels
		initCarousel("creative-carousel");
		initCarousel("fables-carousel");

		// Media Zoom Modal (imagen + video)
		const modal = document.getElementById(
			"media-modal",
		) as HTMLDialogElement | null;
		const modalImg = document.getElementById(
			"modal-image",
		) as HTMLImageElement | null;
		const modalVideo = document.getElementById(
			"modal-video",
		) as HTMLVideoElement | null;
		const closeBtn = document.querySelector(".close-media-btn");

		if (!modal || !modalImg || !modalVideo || !closeBtn) return;

		// Guardamos scroll antes de abrir para restaurar al cerrar
		let savedScroll = 0;

		function closeModal() {
			// Detener y limpiar video al cerrar
			if (modalVideo) {
				modalVideo.pause();
				modalVideo.currentTime = 0;
				modalVideo.src = "";
				modalVideo.style.display = "none";
			}
			if (modalImg) {
				modalImg.src = "";
				modalImg.style.display = "none";
			}
			modal!.close();
			// Restaurar posición de scroll después de cerrar el dialog
			requestAnimationFrame(() => {
				window.scrollTo({
					top: savedScroll,
					behavior: "instant" as ScrollBehavior,
				});
			});
		}

		// Escuchar clics en cualquier medio zoomeable
		document.querySelectorAll(".zoomable-media").forEach((el) => {
			el.addEventListener("click", () => {
				// Capturar posición de scroll actual antes de abrir
				savedScroll = window.scrollY || window.pageYOffset;

				const tag = el.tagName.toLowerCase();
				const src =
					(el as HTMLMediaElement).src ||
					(el as HTMLMediaElement).currentSrc;

				if (tag === "video" || src.endsWith(".mp4")) {
					modalImg!.style.display = "none";
					modalVideo!.style.display = "block";
					modalVideo!.src = src;
					modalVideo!.play();
				} else {
					modalVideo!.style.display = "none";
					modalImg!.style.display = "block";
					modalImg!.src = src;
				}

				modal!.showModal();
			});
		});

		closeBtn.addEventListener("click", closeModal);

		// Cerrar al hacer clic fuera del contenido
		modal.addEventListener("click", (e) => {
			if (e.target === modal) {
				closeModal();
			}
		});

		// ESC también restaura posición
		modal.addEventListener("close", () => {
			if (modalVideo) {
				modalVideo.pause();
				modalVideo.currentTime = 0;
				modalVideo.src = "";
				modalVideo.style.display = "none";
			}
			requestAnimationFrame(() => {
				window.scrollTo({
					top: savedScroll,
					behavior: "instant" as ScrollBehavior,
				});
			});
		});
	}

	// Compatibilidad en carga de Astro
	document.addEventListener("astro:page-load", initPoemLogic);
	if (document.readyState === "loading") {
		document.addEventListener("DOMContentLoaded", initPoemLogic);
	} else {
		initPoemLogic();
	}
</script>
