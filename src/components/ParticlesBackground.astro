<canvas id="particles-bg"></canvas>

<style>
    #particles-bg {
        position: fixed;
        inset: 0;
        z-index: 0;
        pointer-events: none;
        opacity: 0.5;
    }
</style>

<script>
    const canvas = document.getElementById("particles-bg") as HTMLCanvasElement;
    const ctx = canvas.getContext("2d")!;

    function resize() {
        canvas.width = window.innerWidth;
        canvas.height = window.innerHeight;
    }
    resize();
    window.addEventListener("resize", resize);

    interface Firefly {
        x: number;
        y: number;
        r: number;
        vy: number;
        amplitude: number;
        freq: number;
        phase: number;
        opacityPhase: number;
        opacitySpeed: number;
        baseOpacity: number;
        blur: number;
    }

    const COUNT = 70;
    let fireflies: Firefly[] = [];

    function spawnFirefly(startFromBottom: boolean = false): Firefly {
        return {
            x: Math.random() * canvas.width,
            y: startFromBottom
                ? canvas.height + Math.random() * 60
                : Math.random() * canvas.height,
            r: 1.2 + Math.random() * 2.5,
            vy: -(0.15 + Math.random() * 0.4),
            amplitude: 15 + Math.random() * 35,
            freq: 0.003 + Math.random() * 0.008,
            phase: Math.random() * Math.PI * 2,
            opacityPhase: Math.random() * Math.PI * 2,
            opacitySpeed: 0.008 + Math.random() * 0.015,
            baseOpacity: 0.3 + Math.random() * 0.5,
            blur: 4 + Math.random() * 10,
        };
    }

    for (let i = 0; i < COUNT; i++) {
        fireflies.push(spawnFirefly(false));
    }

    let t = 0;

    function animate() {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        t++;

        fireflies.forEach((f) => {
            // Movement
            f.y += f.vy;
            const oscillation = Math.sin(t * f.freq + f.phase) * f.amplitude;
            const drawX = f.x + oscillation;

            // Pulsing opacity
            const pulse = Math.sin(t * f.opacitySpeed + f.opacityPhase);
            const opacity = f.baseOpacity * (0.5 + 0.5 * pulse);

            // Recycle when off-screen top
            if (f.y < -20) {
                Object.assign(f, spawnFirefly(true));
            }

            // Draw with glow
            ctx.save();
            ctx.shadowColor = `rgba(0, 230, 118, ${opacity})`;
            ctx.shadowBlur = f.blur;
            ctx.beginPath();
            ctx.arc(drawX, f.y, f.r, 0, Math.PI * 2);
            ctx.fillStyle = `rgba(0, 230, 118, ${opacity})`;
            ctx.fill();
            ctx.restore();
        });

        requestAnimationFrame(animate);
    }

    animate();
</script>
