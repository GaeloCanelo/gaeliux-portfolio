<style>
    .footer-roots {
        position: relative;
        z-index: 2;
        background: #050709;
        border-top: 1px solid rgba(0, 230, 118, 0.15);
        padding: 4rem 10% 2rem;
        overflow: hidden;
        box-shadow: inset 0 60px 80px -40px rgba(0, 230, 118, 0.04),
                    inset 0 2px 0 0 rgba(0, 230, 118, 0.08);
    }

    .footer-grid {
        display: grid;
        grid-template-columns: 1.5fr 1fr;
        gap: 3rem;
        max-width: 1000px;
        margin: 0 auto;
        align-items: start;
    }

    .footer-title {
        font-size: 1.6rem;
        font-weight: 700;
        color: var(--accent);
        margin-bottom: 1rem;
    }

    .footer-text {
        color: rgba(240, 253, 244, 0.7);
        font-size: 1rem;
        line-height: 1.7;
        max-width: 420px;
    }

    .footer-copy {
        margin-top: 1.5rem;
        color: rgba(240, 253, 244, 0.3);
        font-size: 0.8rem;
    }

    .social-title {
        font-size: 1.1rem;
        font-weight: 600;
        color: var(--text-main);
        margin-bottom: 1.2rem;
    }

    .social-links {
        display: flex;
        gap: 1rem;
    }

    .social-btn {
        width: 50px;
        height: 50px;
        border-radius: 50%;
        background: rgba(0, 230, 118, 0.06);
        border: 1px solid rgba(0, 230, 118, 0.15);
        display: grid;
        place-items: center;
        color: var(--text-main);
        text-decoration: none;
        transition: all 0.3s ease;
    }

    .social-btn:hover {
        color: var(--accent);
        transform: translateY(-5px) scale(1.1);
        border-color: rgba(0, 230, 118, 0.4);
        box-shadow: 0 8px 25px rgba(0, 230, 118, 0.15);
    }

    .social-icon {
        width: 24px;
        height: 24px;
        transition: filter 0.3s ease;
    }

    .social-btn:hover .social-icon {
        filter: drop-shadow(0 0 12px rgba(0, 230, 118, 0.8));
    }

    /* Root decoration */
    .root-decoration {
        margin-top: 3rem;
        opacity: 0.6;
    }

    .roots-svg {
        width: 100%;
        height: 60px;
    }

    /* Mobile */
    @media (max-width: 768px) {
        .footer-roots {
            padding: 3rem 5% 1.5rem;
        }

        .footer-grid {
            grid-template-columns: 1fr;
            text-align: center;
            gap: 2rem;
        }

        .footer-text {
            max-width: 100%;
        }

        .social-links {
            justify-content: center;
        }
    }
</style>
