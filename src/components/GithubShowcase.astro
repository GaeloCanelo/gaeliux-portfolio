---
const reposList = [
    "GaeloCanelo/GNS3-AI-Architect",
    "GaeloCanelo/Carrito_Interfaz",
    "GaeloCanelo/Carrito",
    "GaeloCanelo/Lector-CSV",
    "GaeloCanelo/P02",
];

const fallbackDescriptions: Record<string, string> = {
    "GNS3-AI-Architect": "Agente AI CLI que automatiza topologías y validaciones dentro de proyectos de red GNS3.",
    "Carrito_Interfaz": "Interfaz de usuario responsiva para un sistema frontend de carrito de compras E-commerce.",
    "Carrito": "Lógica y backend de arquitectura orientada al flujo de comercio electrónico.",
    "Lector-CSV": "Aplicación y algoritmo eficiente para procesar y desplegar archivos estructurados en formato CSV.",
    "P02": "Proyecto académico integral enfocando en algoritmos y estructuras de la información."
};

const headers: Record<string, string> = {
    "Accept": "application/vnd.github.html"
};

// Intenta usar token si existe en .env (para subir el límite de 60 a 5000 peticiones/hora)
if (import.meta.env && import.meta.env.GITHUB_TOKEN) {
    headers["Authorization"] = `token ${import.meta.env.GITHUB_TOKEN}`;
}

const generateFallbackRepo = (repoPath: string) => {
    const [owner, name] = repoPath.split('/');
    return {
        data: {
            name,
            owner: { login: owner, avatar_url: `https://github.com/${owner}.png` },
            description: fallbackDescriptions[name] || "Repositorio en proceso de refactorización.",
            html_url: `https://github.com/${repoPath}`,
            stargazers_count: "~",
            forks_count: "-",
            language: "Code",
            message: undefined // Para no ser filtrado
        },
        htmlReadme: `<h2>⚠️ Límite de la API de GitHub superado</h2><p>Durante el desarrollo continuo (Auto-Reload), tu IP alcanzó rápidamente el límite estándar de GitHub (60 peticiones/hora).</p><p><strong>¿Cómo arreglarlo permanentemente en tu Servidor Local?</strong><br/>Genera un token clásico en GitHub (Tokens/Classic), crea un archivo <code>.env</code> en la raíz de tu proyecto e inserta:<br/><code>GITHUB_TOKEN="tu_token_aqui"</code></p>`
    };
};

const reposData = await Promise.all(
    reposList.map(async (repo) => {
        try {
            const res = await fetch(`https://api.github.com/repos/${repo}`, { 
                headers: import.meta.env && import.meta.env.GITHUB_TOKEN ? { "Authorization": `token ${import.meta.env.GITHUB_TOKEN}` } : {}
            });
            const data = await res.json();
            
            // Si llegamos al rate limit, renderizamos la tarjeta fallback visual (fake) para no romper UI
            if (data.message && data.message.includes("API rate limit")) {
                return generateFallbackRepo(repo);
            }
            if (!res.ok) return generateFallbackRepo(repo);
            
            let htmlReadme = "";
            try {
                const readmeRes = await fetch(
                    `https://api.github.com/repos/${repo}/readme`,
                    { headers }
                );
                if (readmeRes.ok) {
                    htmlReadme = await readmeRes.text();
                } else {
                    htmlReadme = "<p>No README encontrado o límite límite alcanzado recuperando el archivo interno.</p>";
                }
            } catch (e) {
                console.error(`Error fetching readme for ${repo}:`, e);
            }

            return { data, htmlReadme };
        } catch (e) {
            console.error(`Error fetching repo ${repo}:`, e);
            return generateFallbackRepo(repo);
        }
    })
);

// Filtramos undefined
const validRepos = reposData.filter(r => r && r.data && !r.data.message);
---

<section class="github-showcase">
    <div class="github-carousel-wrapper reveal">
        <button class="github-nav prev-github" aria-label="Anterior">❮</button>

        <div class="github-carousel" id="github-carousel">
            <div class="github-track">
                {validRepos.map(({ data, htmlReadme }, index) => (
                    <div class="github-card">
                        <div class="repo-header">
                            <img src={data.owner.avatar_url} class="repo-avatar" alt={`Avatar de ${data.owner.login}`}/>
                            <div>
                                <h3>{data.name}</h3>
                                <p>@{data.owner.login}</p>
                            </div>
                        </div>

                        <p class="repo-desc">{data.description || fallbackDescriptions[data.name] || "Repositorio de desarrollo de software y experimentación técnica en GitHub."}</p>

                        <div class="repo-stats">
                            <div class="stat">⭐ {data.stargazers_count}</div>
                            <div class="stat">🍴 {data.forks_count}</div>
                            {data.language && <div class="stat">{data.language}</div>}
                        </div>

                        <div class="repo-actions">
                            <a href={data.html_url} target="_blank" class="repo-btn">
                                Ver Repo
                            </a>
                            {htmlReadme && (
                                <button class="repo-btn readme-btn" data-dialog-id={`dialog-${index}`}>
                                    Leer más
                                </button>
                            )}
                        </div>

                        {htmlReadme && (
                            <dialog id={`dialog-${index}`} class="readme-modal">
                                <div class="modal-content">
                                    <button class="close-modal-btn" aria-label="Cerrar modal">✕</button>
                                    <div class="markdown-body" set:html={htmlReadme}></div>
                                </div>
                            </dialog>
                        )}
                    </div>
                ))}
                
                {validRepos.length === 0 && (
                    <div class="github-card">
                        <p>Los repositorios no pudieron cargarse. Quizás se alcanzó el límite de la API.</p>
                    </div>
                )}
            </div>
        </div>

        <button class="github-nav next-github" aria-label="Siguiente">❯</button>
    </div>
</section>

<style>
    .github-showcase {
        padding: 4rem 10%;
        position: relative;
        z-index: 2;
    }

    .github-carousel-wrapper {
        position: relative;
        display: flex;
        align-items: center;
    }

    .github-carousel {
        overflow: hidden;
        width: 100%;
        padding: 2rem 0;
        --card-width: calc((100% - 4rem) / 3);
    }

    .github-track {
        display: flex;
        gap: 2rem;
        width: max-content;
        transition: transform 0.6s cubic-bezier(0.25, 1, 0.5, 1);
    }

    .github-card {
        flex: 0 0 auto;
        width: var(--card-width);
        min-width: 320px;
        max-width: 420px;
        padding: 2rem;
        border-radius: 24px;
        position: relative;
        transform-style: preserve-3d;
        perspective: 1000px;
        scroll-snap-align: center;

        background:
            radial-gradient(
                circle at var(--mouse-x, 50%) var(--mouse-y, 50%),
                rgba(255, 255, 255, 0.15),
                transparent 30%
            ),
            linear-gradient(
                135deg,
                rgba(0, 230, 118, 0.1),
                rgba(0, 150, 255, 0.1),
                rgba(120, 0, 255, 0.1)
            );

        backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        box-shadow: 0 15px 35px rgba(0, 0, 0, 0.25);
        transition: transform 0.15s ease, box-shadow 0.3s ease;
    }

    @media (hover: hover) {
        .github-card:hover {
            box-shadow: 0 25px 50px rgba(0, 230, 118, 0.15);
        }
    }

    .repo-header {
        display: flex;
        gap: 1rem;
        align-items: center;
    }

    .repo-avatar {
        width: 55px;
        height: 55px;
        border-radius: 50%;
    }
    
    .repo-desc {
        margin-top: 1rem;
        min-height: 3rem; /* maintain alignment */
    }

    .repo-stats {
        display: flex;
        gap: 1rem;
        margin: 1rem 0;
        flex-wrap: wrap;
    }

    .stat {
        padding: 0.5rem 0.8rem;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.07);
    }

    .repo-actions {
        display: flex;
        gap: 0.6rem;
        margin-top: 1rem;
    }

    .repo-btn {
        padding: 0.6rem 1rem;
        border: none;
        border-radius: 10px;
        background: var(--accent, #00e676);
        color: black;
        font-weight: bold;
        cursor: pointer;
        text-decoration: none;
        transition: background 0.3s, transform 0.1s;
    }
    
    .repo-btn:hover {
        filter: brightness(1.1);
    }

    .repo-btn:active {
        transform: scale(0.95);
    }

    .readme-btn {
        background: rgba(255, 255, 255, 0.1);
        color: white;
        border: 1px solid rgba(255, 255, 255, 0.2);
    }
    
    .readme-btn:hover {
        background: rgba(255, 255, 255, 0.2);
    }

    .github-nav {
        position: absolute;
        width: 50px;
        height: 50px;
        border: none;
        border-radius: 50%;
        background: var(--bg-card, #222);
        color: var(--accent, #00e676);
        cursor: pointer;
        z-index: 5;
        transition: transform 0.2s, background 0.2s;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
        box-shadow: 0 5px 15px rgba(0, 0, 0, 0.5);
    }
    
    .github-nav:hover {
        transform: scale(1.15);
        background: #333;
        box-shadow: 0 5px 25px rgba(0, 230, 118, 0.4);
    }

    .prev-github { left: -30px; }
    .next-github { right: -30px; }

    @media (max-width: 768px) {
        .github-nav {
            display: none;
        }
        .github-showcase {
            padding: 2rem 5%;
        }
        .github-carousel {
            overflow-x: auto;
            scroll-snap-type: x mandatory;
            scroll-behavior: smooth;
            scrollbar-width: none;
        }
        .github-carousel::-webkit-scrollbar {
            display: none;
        }
        .github-track {
            transition: none;
            transform: none !important;
        }
        .github-card {
            scroll-snap-align: center;
        }
    }

    /* Modal dialog */
    .readme-modal {
        border: none;
        border-radius: 16px;
        background: var(--bg-main, #080a10);
        color: var(--text-main, #f0fdf4);
        max-width: 800px;
        width: 90vw;
        max-height: 85vh;
        margin: auto;
        padding: 0;
        box-shadow: 0 25px 50px rgba(0,0,0,0.5);
    }
    
    .readme-modal::backdrop {
        background: rgba(0,0,0,0.7);
        backdrop-filter: blur(5px);
    }
    
    .modal-content {
        padding: 2.5rem 2rem;
        position: relative;
        overflow-y: auto;
        max-height: 85vh;
    }
    
    .close-modal-btn {
        position: absolute;
        top: 15px;
        right: 15px;
        background: rgba(255,255,255,0.1);
        border: none;
        color: white;
        width: 35px;
        height: 35px;
        border-radius: 50%;
        cursor: pointer;
        font-size: 1.2rem;
        display: grid;
        place-items: center;
        transition: 0.3s;
    }
    
    .close-modal-btn:hover {
        background: rgba(255,0,0,0.6);
        transform: rotate(90deg);
    }

    /* Basic Markdown Styles for injected HTML */
    .markdown-body {
        font-family: system-ui, sans-serif;
        line-height: 1.6;
        font-size: 0.95rem;
    }
    .markdown-body h1, .markdown-body h2, .markdown-body h3 {
        color: var(--accent, #00e676);
        margin-top: 1.5rem;
        margin-bottom: 1rem;
        border-bottom: 1px solid rgba(255,255,255,0.1);
        padding-bottom: 0.5rem;
    }
    .markdown-body a {
        color: var(--accent, #00e676);
        text-decoration: none;
    }
    .markdown-body a:hover {
        text-decoration: underline;
    }
    .markdown-body code {
        background: rgba(255,255,255,0.1);
        padding: 0.2rem 0.4rem;
        border-radius: 4px;
        font-family: monospace;
        font-size: 0.85em;
    }
    .markdown-body pre {
        background: #111;
        padding: 1rem;
        border-radius: 8px;
        overflow-x: auto;
        margin: 1rem 0;
    }
    .markdown-body img {
        max-width: 100%;
        border-radius: 8px;
    }
    .markdown-body ul, .markdown-body ol {
        padding-left: 2rem;
        margin-bottom: 1rem;
    }

    .reveal {
        opacity: 0;
        transform: translateY(40px);
        transition: all 0.8s ease;
    }

    .reveal.active {
        opacity: 1;
        transform: translateY(0);
    }
</style>

<script>
    function initEffects() {
        const isTouchDevice = 'ontouchstart' in window || navigator.maxTouchPoints > 0;
        
        if (!isTouchDevice) {
            document.querySelectorAll(".github-card").forEach((card) => {
                const el = card as HTMLElement;
                
                el.addEventListener("mousemove", (e: MouseEvent) => {
                    const rect = el.getBoundingClientRect();
                    const x = e.clientX - rect.left;
                    const y = e.clientY - rect.top;

                    el.style.setProperty("--mouse-x", `${x}px`);
                    el.style.setProperty("--mouse-y", `${y}px`);

                    const rotateY = (x - rect.width / 2) / 20;
                    const rotateX = -(y - rect.height / 2) / 20;

                    el.style.transform = `rotateX(${rotateX}deg) rotateY(${rotateY}deg)`;
                });

                el.addEventListener("mouseleave", () => {
                    el.style.transform = "rotateX(0) rotateY(0)";
                });
            });
        }
        
        // Modal logic — con protección de scroll
        let ghSavedScroll = 0;

        document.querySelectorAll(".readme-btn").forEach((btn) => {
            btn.addEventListener("click", () => {
                ghSavedScroll = window.scrollY || window.pageYOffset;
                const dialogId = btn.getAttribute("data-dialog-id");
                const dialog = document.getElementById(dialogId) as HTMLDialogElement;
                if(dialog) dialog.showModal();
            });
        });

        document.querySelectorAll(".close-modal-btn").forEach((btn) => {
            btn.addEventListener("click", () => {
                const dialog = btn.closest("dialog") as HTMLDialogElement;
                if(dialog) dialog.close();
                requestAnimationFrame(() => {
                    window.scrollTo({ top: ghSavedScroll, behavior: "instant" as ScrollBehavior });
                });
            });
        });

        document.querySelectorAll(".readme-modal").forEach((dialog) => {
            dialog.addEventListener("click", (e) => {
                const dialogElement = dialog as HTMLDialogElement;
                const rect = dialogElement.getBoundingClientRect();
                const isInDialog = (rect.top <= e.clientY && e.clientY <= rect.top + rect.height &&
                  rect.left <= e.clientX && e.clientX <= rect.left + rect.width);
                if (!isInDialog) {
                    dialogElement.close();
                    requestAnimationFrame(() => {
                        window.scrollTo({ top: ghSavedScroll, behavior: "instant" as ScrollBehavior });
                    });
                }
            });
        });
        
        // Carousel Navigation (Smooth Transform Desktop)
        const carousel = document.getElementById("github-carousel");
        const track = carousel?.querySelector(".github-track") as HTMLElement | null;
        const nextBtn = document.querySelector(".next-github");
        const prevBtn = document.querySelector(".prev-github");
        
        if(carousel && track && nextBtn && prevBtn) {
            let currentOffset = 0;
            
            nextBtn.addEventListener("click", () => {
                const card = track.querySelector(".github-card") as HTMLElement | null;
                if(card) {
                    const cardWidth = card.offsetWidth;
                    const gap = parseFloat(window.getComputedStyle(track).gap) || 32;
                    const shift = cardWidth + gap;
                    
                    // Límite derecho rudimentario
                    const maxScroll = track.scrollWidth - carousel.clientWidth;
                    if(Math.abs(currentOffset) < maxScroll) {
                        currentOffset -= shift;
                        // Si sobrepasa, ajustarlo al max
                        if(Math.abs(currentOffset) > maxScroll) currentOffset = -maxScroll;
                        track.style.transform = `translateX(${currentOffset}px)`;
                    }
                }
            });
            
            prevBtn.addEventListener("click", () => {
                const card = track.querySelector(".github-card") as HTMLElement | null;
                if(card) {
                    const cardWidth = card.offsetWidth;
                    const gap = parseFloat(window.getComputedStyle(track).gap) || 32;
                    const shift = cardWidth + gap;
                    
                    currentOffset += shift;
                    if(currentOffset > 0) currentOffset = 0;
                    
                    track.style.transform = `translateX(${currentOffset}px)`;
                }
            });
        }

        // Scroll Reveal
        const observer = new IntersectionObserver((entries) => {
            entries.forEach((entry) => {
                if (entry.isIntersecting) {
                    entry.target.classList.add("active");
                    observer.unobserve(entry.target);
                }
            });
        }, { threshold: 0.1 });

        document.querySelectorAll(".reveal").forEach((el) => observer.observe(el));
    }

    // Astro view transitions support
    document.addEventListener("astro:page-load", initEffects);
    // Initial load compatibility
    if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", initEffects);
    } else {
        initEffects();
    }
</script>
